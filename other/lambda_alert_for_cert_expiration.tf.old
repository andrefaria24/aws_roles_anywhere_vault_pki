/*
This logic triggers:

When remaining_days hits 90
When it hits 60
When it hits 30
And continues alerting under 30 (critical state)

The Lambda runs daily, you’ll get:
One alert at 90
One at 60
One at 30
Then daily alerts under 30
*/

# sns
resource "aws_sns_topic" "ta_expiry_alerts" {
  name = "rolesanywhere-trust-anchor-expiry"
}

resource "aws_sns_topic_subscription" "email" {
  topic_arn = aws_sns_topic.ta_expiry_alerts.arn
  protocol  = "email"
  endpoint  = "engineer@company.com" # <-- change this
}

# lambda role
resource "aws_iam_role" "ta_lambda_role" {
  name = "ta-expiry-lambda-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [{
      Effect = "Allow"
      Principal = {
        Service = "lambda.amazonaws.com"
      }
      Action = "sts:AssumeRole"
    }]
  })
}

# lambda policy
resource "aws_iam_role_policy" "ta_lambda_policy" {
  name = "ta-expiry-policy"
  role = aws_iam_role.ta_lambda_role.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "rolesanywhere:ListTrustAnchors",
          "rolesanywhere:ListTagsForResource"
        ]
        Resource = "*"
      },
      {
        Effect   = "Allow"
        Action   = "sns:Publish"
        Resource = aws_sns_topic.ta_expiry_alerts.arn
      },
      {
        Effect = "Allow"
        Action = [
          "logs:CreateLogGroup",
          "logs:CreateLogStream",
          "logs:PutLogEvents"
        ]
        Resource = "*"
      }
    ]
  })
}

# lamdba resource
data "archive_file" "lambda_zip" {
  type        = "zip"
  source_file = "${path.module}/lambda/ta_expiry.py"
  output_path = "${path.module}/lambda/ta_expiry.zip"
}

resource "aws_lambda_function" "ta_expiry" {
  function_name = "rolesanywhere-ta-expiry-check"
  role          = aws_iam_role.ta_lambda_role.arn
  handler       = "ta_expiry.lambda_handler"
  runtime       = "python3.12"

  filename         = data.archive_file.lambda_zip.output_path
  source_code_hash = data.archive_file.lambda_zip.output_base64sha256

  environment {
    variables = {
      SNS_TOPIC_ARN  = aws_sns_topic.ta_expiry_alerts.arn
      THRESHOLD_DAYS = "30"
    }
  }
}

# eventbridge rule to trigger lambda daily
resource "aws_cloudwatch_event_rule" "daily" {
  name                = "ta-expiry-daily-check"
  schedule_expression = "rate(1 day)"
}

# connect rule to lambda
resource "aws_cloudwatch_event_target" "lambda_target" {
  rule      = aws_cloudwatch_event_rule.daily.name
  target_id = "lambda"
  arn       = aws_lambda_function.ta_expiry.arn
}

resource "aws_lambda_permission" "allow_eventbridge" {
  statement_id  = "AllowExecutionFromEventBridge"
  action        = "lambda:InvokeFunction"
  function_name = aws_lambda_function.ta_expiry.function_name
  principal     = "events.amazonaws.com"
  source_arn    = aws_cloudwatch_event_rule.daily.arn
}
